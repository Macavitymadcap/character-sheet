{
  "name": "character-sheet",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "protect:branches": "bun scripts/configure-branch-protection.ts",
    "protect:branches:bootstrap": "bun scripts/configure-branch-protection.ts --bootstrap",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:a11y": "bun scripts/test-a11y.ts",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
