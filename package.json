{
  "name": "campaign-ledger",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "db:bootstrap": "bun scripts/db-bootstrap.ts",
    "dev": "bun run --hot src/index.ts",
    "import:rules": "bun scripts/import-rules.ts",
    "import:rules:srd": "bun scripts/import-rules.ts docs/rules/srd-5.1",
    "hosted:data": "bun scripts/hosted-data.ts",
    "hosted:check": "bun scripts/hosted-health.ts",
    "hosted:rehearse": "bun scripts/fresh-hosted-rehearsal.ts",
    "protect:branches": "bun scripts/configure-branch-protection.ts",
    "protect:branches:bootstrap": "bun scripts/configure-branch-protection.ts --bootstrap",
    "screenshots:sheet": "bun -e \"import { captureSheetScreenshots } from './scripts/capture-screenshots'; await captureSheetScreenshots();\"",
    "seed": "bun scripts/db-bootstrap.ts",
    "smoke:mvp": "bun -e \"import { runMvpSmoke } from './scripts/smoke-mvp'; await runMvpSmoke();\"",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:a11y": "bun scripts/test-a11y.ts",
    "test:hyper-dank": "bun test scripts/hyper-dank-compat.test.tsx",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "update:hyper-dank": "bun update @macavitymadcap/hyper-dank-automation @macavitymadcap/hyper-dank-data @macavitymadcap/hyper-dank-transport @macavitymadcap/hyper-dank-ui && bun run test:hyper-dank",
    "verify": "bun scripts/verify.ts"
  },
  "dependencies": {
    "@macavitymadcap/hyper-dank-automation": "^0.2.0",
    "@macavitymadcap/hyper-dank-data": "^0.2.0",
    "@macavitymadcap/hyper-dank-transport": "^0.2.0",
    "@macavitymadcap/hyper-dank-ui": "^0.2.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pa11y": "^9.1.1",
    "puppeteer": "^25.0.2",
    "typescript": "^5"
  }
}
